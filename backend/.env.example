# DoConnect AI — Backend Environment Variables
# Copy this file to .env and configure the variables for your environment.
# Never commit the .env file if it contains real production secrets.

# ── Server Configuration ──────────────────────────────────────────────────────
# The port the backend will run on
SERVER_PORT=8080

# ── Database Configuration ────────────────────────────────────────────────────
# JDBC connection string for the backend MySQL database
DB_URL=jdbc:mysql://localhost:3306/doconnect_ai?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# Hibernate DDL auto strategy. 
# CAUTION: Set to 'validate' or 'none' in production to prevent data loss.
JPA_DDL_AUTO=update

# ── Security & Authentication ─────────────────────────────────────────────────
# The secret key used to sign and verify JWT tokens.
# Must be at least 32 characters long.
JWT_SECRET=your-secure-jwt-secret-here-at-least-32-chars
JWT_EXPIRATION_MINUTES=1440

# ── Notifications & CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
NOTIFICATION_ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Token used for internal service-to-service communication (e.g. Chat Service talking to Backend)
NOTIFICATION_INTERNAL_TOKEN=your-secure-internal-communication-token

# ── Gemini AI Engine Configuration ────────────────────────────────────────────
# Your Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_TIMEOUT_SECONDS=30
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_OUTPUT_TOKENS=1200
