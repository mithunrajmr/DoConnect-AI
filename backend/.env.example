# DoConnect AI — Backend Environment Variables
# Copy this file to a local environment or set these variables in your
# deployment platform. Never commit a file containing real secrets.
#
# Usage (Linux/macOS):
#   export JWT_SECRET="$(openssl rand -base64 48)"
#   export NOTIFICATION_INTERNAL_TOKEN="$(openssl rand -base64 32)"
#
# Usage (Windows PowerShell):
#   $Env:JWT_SECRET = "your-secret-here"

# ── Server ──────────────────────────────────────────────────────────────────
# Port the Spring Boot application listens on.
SERVER_PORT=8080

# ── Database ────────────────────────────────────────────────────────────────
# Full JDBC URL to your MySQL instance.
# The 'doconnect_ai' schema must exist before starting the application.
DB_URL=jdbc:mysql://localhost:3306/doconnect_ai?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# MySQL credentials. Use a dedicated application user, NOT root, in production.
DB_USERNAME=appuser
DB_PASSWORD=change-me

# Hibernate DDL strategy.
# Development: update  |  Production: validate  (use Flyway/Liquibase for migrations)
JPA_DDL_AUTO=update

# ── JWT Authentication ───────────────────────────────────────────────────────
# REQUIRED. HMAC-SHA256 signing secret — minimum 32 characters.
# Generate with: openssl rand -base64 48
# The app will REFUSE to start if this is blank or shorter than 32 characters.
# This secret MUST be identical in the chat-service.
JWT_SECRET=

# Token lifetime in minutes (default: 1440 = 24 hours).
JWT_EXPIRATION_MINUTES=1440

# ── WebSocket / Notifications ────────────────────────────────────────────────
# Comma-separated list of origins allowed to open a WebSocket connection.
# In production, replace with your actual frontend URL(s).
NOTIFICATION_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# REQUIRED. Shared secret between the chat-service and this backend.
# Used to authenticate the internal chat-event forwarding HTTP call.
# Generate with: openssl rand -base64 32
# Must be identical in both services.
NOTIFICATION_INTERNAL_TOKEN=

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Your Google AI Studio API key.
# Get one at: https://aistudio.google.com/app/apikey
# If blank, all AI features (answer suggestions, summaries, tag prediction)
# will return an error response; the rest of the app continues normally.
GEMINI_API_KEY=

# Gemini model name (see https://ai.google.dev/models/gemini for options).
GEMINI_MODEL=gemini-2.0-flash

# Base URL for the Gemini REST API. Do not change unless using a proxy.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Request timeout in seconds.
GEMINI_TIMEOUT_SECONDS=30

# Model temperature (0.0 – 1.0). Lower = more deterministic.
GEMINI_TEMPERATURE=0.35

# Maximum tokens the model may emit in a single response.
GEMINI_MAX_OUTPUT_TOKENS=1200
