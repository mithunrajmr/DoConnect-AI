# DoConnect AI — Frontend Environment Variables
# Copy this file to .env.local (for local dev) or set these variables in your
# CI/CD pipeline or static hosting platform at build time.
# Never commit a file containing real values if they are sensitive.
#
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# ── API Base URL ──────────────────────────────────────────────────────────────
# The root URL for the main backend REST API.
#
# Development: leave blank to use the Vite proxy.
# Production:  set to the public URL of your deployed backend, e.g.:
#              https://api.yourdomain.com
VITE_API_URL=

# ── Notification WebSocket URL ────────────────────────────────────────────────
# Full WebSocket URL for the main backend's notification endpoint.
#
# Development: leave blank to use the Vite proxy.
# Production:  set to the public WebSocket URL of your deployed backend, e.g.:
#              wss://api.yourdomain.com/ws/notifications
VITE_NOTIFY_WS_URL=

# ── Chat WebSocket URL ────────────────────────────────────────────────────────
# Full WebSocket URL for the chat microservice.
#
# Development: leave blank to use the Vite proxy.
# Production:  set to the public WebSocket URL of your deployed chat service, e.g.:
#              wss://chat.yourdomain.com/ws
VITE_CHAT_WS_URL=
