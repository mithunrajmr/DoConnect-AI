# DoConnect AI — Chat Service Environment Variables
# Copy this file to .env and configure the variables for your environment.
# Never commit the .env file if it contains real production secrets.

# ── Server Configuration ──────────────────────────────────────────────────────
# The port the chat microservice will run on
CHAT_SERVER_PORT=8090

# ── Database Configuration ────────────────────────────────────────────────────
# JDBC connection string for the chat service MySQL database
CHAT_DB_URL=jdbc:mysql://localhost:3306/doconnect_chat?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
CHAT_DB_USERNAME=root
CHAT_DB_PASSWORD=root

# Hibernate DDL auto strategy. 
# CAUTION: Set to 'validate' or 'none' in production to prevent data loss.
CHAT_JPA_DDL_AUTO=update

# ── Security & Authentication ─────────────────────────────────────────────────
# The secret key used to verify JWT tokens issued by the main backend.
# MUST exactly match the JWT_SECRET in the backend environment.
JWT_SECRET=your-secure-jwt-secret-here-at-least-32-chars

# ── Chat & CORS Configuration ─────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend WebSocket connections.
CHAT_ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Configuration limits for chat rooms
CHAT_GLOBAL_ROOM_ID=global
CHAT_HISTORY_DEFAULT_LIMIT=50
CHAT_HISTORY_MAX_LIMIT=200

# ── Microservice Communication ────────────────────────────────────────────────
# The URL of the main backend API. Used for cross-service notifications.
NOTIFICATION_BACKEND_URL=http://localhost:8080

# Token used to authenticate requests made TO the main backend.
# MUST exactly match NOTIFICATION_INTERNAL_TOKEN in the backend environment.
NOTIFICATION_INTERNAL_TOKEN=your-secure-internal-communication-token
