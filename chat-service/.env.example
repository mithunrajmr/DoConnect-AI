# DoConnect AI — Chat Service Environment Variables
# Copy this file to a local environment or set these variables in your
# deployment platform. Never commit a file containing real secrets.

# ── Server ──────────────────────────────────────────────────────────────────
# Port the chat microservice listens on.
CHAT_SERVER_PORT=8090

# ── Database ────────────────────────────────────────────────────────────────
# Full JDBC URL to your MySQL instance.
# The 'doconnect_chat' schema must exist before starting the service.
CHAT_DB_URL=jdbc:mysql://localhost:3306/doconnect_chat?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# MySQL credentials for the chat database.
# If CHAT_DB_USERNAME / CHAT_DB_PASSWORD are not set, the service falls back
# to DB_USERNAME / DB_PASSWORD (useful when both services share one user).
CHAT_DB_USERNAME=appuser
CHAT_DB_PASSWORD=change-me

# Hibernate DDL strategy.
# Development: update  |  Production: validate
CHAT_JPA_DDL_AUTO=update

# ── JWT Authentication ───────────────────────────────────────────────────────
# REQUIRED. Must be identical to the JWT_SECRET in the main backend.
# The chat service only validates tokens; it does not issue them.
# The app will REFUSE to start if this is blank or shorter than 32 characters.
JWT_SECRET=

# ── WebSocket ────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to open a WebSocket connection.
# In production, replace with your actual frontend URL(s).
CHAT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Global room identifier used as the STOMP topic suffix.
CHAT_GLOBAL_ROOM_ID=global

# Default number of messages returned by the history endpoint.
CHAT_HISTORY_DEFAULT_LIMIT=50

# Hard maximum for history queries.
CHAT_HISTORY_MAX_LIMIT=200

# ── Backend Integration ───────────────────────────────────────────────────────
# Base URL of the main DoConnect backend.
# The chat service POSTs chat-notification events to this address.
NOTIFICATION_BACKEND_URL=http://localhost:8080

# REQUIRED. Must be identical to NOTIFICATION_INTERNAL_TOKEN in the backend.
# This token authenticates the inter-service call; keep it secret.
NOTIFICATION_INTERNAL_TOKEN=
